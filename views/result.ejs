<!DOCTYPE html>
<html lang="ko">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Univ_Pass - 분석 결과</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
  <link rel="stylesheet" href="/style.css">
</head>
<body>
  <div class="container py-5">
    <div class="d-flex flex-wrap justify-content-between align-items-center mb-4">
      <div>
        <h1 class="fw-bold" style="font-size:1.8rem; color:var(--primary);">분석 결과</h1>
        <p class="text-muted mb-0"><%= student.name %>님의 수시 합격 확률 분석</p>
      </div>
      <div class="d-flex gap-2 mt-2 mt-md-0 align-items-center">
        <div id="saveIndicator" style="<%= savedId ? '' : 'display:none' %>" class="small text-success fw-semibold">
          ✅ 저장됨 <a href="/saved/<%= savedId %>" class="text-decoration-none">#</a>
        </div>
        <button type="button" class="btn btn-sm btn-outline-success" id="saveBtn" onclick="saveResult()" <%= savedId ? 'disabled' : '' %>>💾 저장</button>
        <a href="/saved" class="btn btn-outline-secondary btn-sm">저장 목록</a>
        <a href="/admin" class="btn btn-outline-secondary btn-sm">기준 관리</a>
        <a href="/" class="btn btn-outline-primary btn-sm">새 분석</a>
      </div>
    </div>

    <div class="row justify-content-center">
      <div class="col-lg-10">
        <div class="card shadow-sm mb-4">
          <div class="card-body p-4">
            <h4 class="section-title">입력 정보 요약</h4>
            <div class="row g-3">
              <div class="col-md-4">
                <div class="stat-box">
                  <div class="stat-label">내신 등급</div>
                  <div class="stat-value" style="color:var(--primary);"><%= Number(student.gpa_grade).toFixed(2) %></div>
                </div>
              </div>
              <div class="col-md-4">
                <div class="stat-box">
                  <div class="stat-label">내신 환산 점수</div>
                  <div class="stat-value" style="color:var(--success);"><%= results.length > 0 ? results[0].gpaScore : 0 %></div>
                </div>
              </div>
              <div class="col-md-4">
                <div class="stat-box">
                  <div class="stat-label">학생부 총점</div>
                  <div class="stat-value" style="color:var(--primary-light);">
                    <% 
                      var totalRecord = 0
                      var recordKeys = ['academic_competency','learning_attitude','career_competency','career_exploration','character','leadership']
                      recordKeys.forEach(function(k) { totalRecord += Number(student.record_scores[k]) })
                    %>
                    <%= totalRecord %> <span style="font-size:1rem;">/ 60</span>
                  </div>
                </div>
              </div>
            </div>
          </div>
        </div>

        <div class="card shadow-sm mb-4">
          <div class="card-body p-4">
            <h4 class="section-title d-flex align-items-center gap-2">
              합격 확률
              <span class="badge bg-secondary fs-6" style="font-size:0.8rem !important;"><%= admissionType %> · <%= deptQuery ? deptQuery + ' 관련 ' : '' %>총 <%= totalUnivs %>개 학과 분석</span>
            </h4>

            <% if (highProb.length > 0) { %>
              <div class="result-section-high mb-4">
                <h5 class="fw-bold mb-3" style="color:var(--success);">합격 가능성이 높아요 (70% 이상)</h5>
              </div>
              <div class="table-responsive mb-4">
                    <table class="table table-hover align-middle">
                    <thead>
                      <tr>
                        <th>대학교</th>
                        <th>학과</th>
                        <th>전형</th>
                        <th>내신점수</th>
                        <th>학생부점수</th>
                        <th>최종점수</th>
                        <th>합격컷</th>
                        <th>확률</th>
                        <th>게이지</th>
                      </tr>
                    </thead>
                    <tbody>
                      <% highProb.forEach(function(r) { %>
                        <tr>
                          <td class="fw-medium">
                            <%= r.university %>
                            <a href="/admin/<%= r.universityId %>" class="text-decoration-none small ms-1" title="기준 편집" style="color:var(--gray-400);">편집</a>
                          </td>
                          <td><%= r.department %></td>
                          <td><span class="badge bg-secondary"><%= r.admissionType || admissionType || '종합' %></span></td>
                          <% if (r.cutoffIsGrade) { %>
                            <td><%= Number(student.gpa_grade).toFixed(2) %>등급</td>
                            <td>-</td>
                            <td><%= r.gpaScore %></td>
                            <td><%= r.cutoffRaw %>등급</td>
                          <% } else { %>
                            <td><%= r.gpaScore %></td>
                            <td><%= Math.round(r.recordScore) %></td>
                            <td><%= r.totalScore %></td>
                            <td><%= r.cutoffScore %></td>
                          <% } %>
                          <td class="fw-bold" style="color:var(--success);"><%= r.probability %>%</td>
                          <td class="gauge-cell">
                            <div class="progress" style="height:20px;">
                              <div class="progress-bar bg-success" style="width:<%= Math.min(r.probability, 100) %>%"><%= Math.round(r.probability) %>%</div>
                            </div>
                          </td>
                        </tr>
                      <% }) %>
                    </tbody>
                  </table>
              </div>
            <% } %>

            <% if (midProb.length > 0) { %>
              <div class="result-section-mid mb-4">
                <h5 class="fw-bold mb-3" style="color:var(--warning);">도전해볼 만해요 (40%~70%)</h5>
              </div>
              <div class="table-responsive mb-4">
                  <table class="table table-hover align-middle">
                    <thead>
                      <tr>
                        <th>대학교</th>
                        <th>학과</th>
                        <th>전형</th>
                        <th>내신점수</th>
                        <th>학생부점수</th>
                        <th>최종점수</th>
                        <th>합격컷</th>
                        <th>확률</th>
                        <th>게이지</th>
                      </tr>
                    </thead>
                    <tbody>
                      <% midProb.forEach(function(r) { %>
                        <tr>
                          <td class="fw-medium">
                            <%= r.university %>
                            <a href="/admin/<%= r.universityId %>" class="text-decoration-none small ms-1" title="기준 편집" style="color:var(--gray-400);">편집</a>
                          </td>
                          <td><%= r.department %></td>
                          <td><span class="badge bg-secondary"><%= r.admissionType || admissionType || '종합' %></span></td>
                          <% if (r.cutoffIsGrade) { %>
                            <td><%= Number(student.gpa_grade).toFixed(2) %>등급</td>
                            <td>-</td>
                            <td><%= r.gpaScore %></td>
                            <td><%= r.cutoffRaw %>등급</td>
                          <% } else { %>
                            <td><%= r.gpaScore %></td>
                            <td><%= Math.round(r.recordScore) %></td>
                            <td><%= r.totalScore %></td>
                            <td><%= r.cutoffScore %></td>
                          <% } %>
                          <td class="fw-bold" style="color:var(--warning);"><%= r.probability %>%</td>
                          <td class="gauge-cell">
                            <div class="progress" style="height:20px;">
                              <div class="progress-bar bg-warning" style="width:<%= Math.min(r.probability, 100) %>%"><%= Math.round(r.probability) %>%</div>
                            </div>
                          </td>
                        </tr>
                      <% }) %>
                    </tbody>
                  </table>
              </div>
            <% } %>

            <% if (lowProb.length > 0) { %>
              <div class="result-section-low mb-4">
                <h5 class="fw-bold mb-3" style="color:var(--danger);">추가 보완이 필요해요 (40% 미만)</h5>
              </div>
              <div class="table-responsive mb-4">
                  <table class="table table-hover align-middle">
                    <thead>
                      <tr>
                        <th>대학교</th>
                        <th>학과</th>
                        <th>전형</th>
                        <th>내신점수</th>
                        <th>학생부점수</th>
                        <th>최종점수</th>
                        <th>합격컷</th>
                        <th>확률</th>
                        <th>게이지</th>
                      </tr>
                    </thead>
                    <tbody>
                      <% lowProb.forEach(function(r) { %>
                        <tr>
                          <td class="fw-medium">
                            <%= r.university %>
                            <a href="/admin/<%= r.universityId %>" class="text-decoration-none small ms-1" title="기준 편집" style="color:var(--gray-400);">편집</a>
                          </td>
                          <td><%= r.department %></td>
                          <td><span class="badge bg-secondary"><%= r.admissionType || admissionType || '종합' %></span></td>
                          <% if (r.cutoffIsGrade) { %>
                            <td><%= Number(student.gpa_grade).toFixed(2) %>등급</td>
                            <td>-</td>
                            <td><%= r.gpaScore %></td>
                            <td><%= r.cutoffRaw %>등급</td>
                          <% } else { %>
                            <td><%= r.gpaScore %></td>
                            <td><%= Math.round(r.recordScore) %></td>
                            <td><%= r.totalScore %></td>
                            <td><%= r.cutoffScore %></td>
                          <% } %>
                          <td class="fw-bold" style="color:var(--danger);"><%= r.probability %>%</td>
                          <td class="gauge-cell">
                            <div class="progress" style="height:20px;">
                              <div class="progress-bar bg-danger" style="width:<%= Math.min(r.probability, 100) %>%"><%= Math.round(r.probability) %>%</div>
                            </div>
                          </td>
                        </tr>
                      <% }) %>
                    </tbody>
                  </table>
              </div>
            <% } %>

            <% if (results.length > 0) { %>
              <div class="advice-card mt-4">
                <h5 class="fw-bold mb-3">수시 분석 코멘트</h5>
                <div class="mb-2"><strong>내신:</strong> <%= results[0].gradeAdvice %></div>
                <div><strong>학생부:</strong> <%= results[0].recordAdvice %></div>
              </div>
            <% } %>
          </div>
        </div>

        <div class="card shadow-sm mb-4">
          <div class="card-body p-4">
            <h4 class="section-title">학생부 상세 분석 <% if (results.length > 0) { %><span class="badge bg-secondary fs-6" style="font-size:0.8rem !important;"><%= results[0].university %> 기준</span><% } %></h4>
            <% if (results.length > 0) { %>
              <div class="table-responsive">
                <table class="table table-bordered">
                  <thead>
                    <tr>
                      <th>항목</th>
                      <th>점수</th>
                      <th>가중치</th>
                      <th>가중점수</th>
                      <th>만점</th>
                      <th>달성률</th>
                    </tr>
                  </thead>
                  <tbody>
                    <% results[0].recordDetails.forEach(function(d) { %>
                      <tr>
                        <td><%= d.label %></td>
                        <td><%= d.score %> / 10</td>
                        <td><%= d.weight %></td>
                        <td><%= d.weighted.toFixed(2) %></td>
                        <td><%= d.maxWeighted.toFixed(2) %></td>
                        <td>
                          <div class="progress" style="height:16px;">
                            <div class="progress-bar <%= d.score >= 8 ? 'bg-success' : (d.score >= 5 ? 'bg-warning' : 'bg-danger') %>" style="width:<%= (d.score / 10) * 100 %>%">
                              <%= Math.round((d.score / 10) * 100) %>%
                            </div>
                          </div>
                        </td>
                      </tr>
                    <% }) %>
                  </tbody>
                </table>
              </div>
            <% } %>
          </div>
        </div>

        <div class="text-center d-flex justify-content-center gap-3 flex-wrap">
          <a href="/" class="btn btn-primary btn-lg">다시 분석하기</a>
          <a href="/admin" class="btn btn-outline-secondary btn-lg">기준 관리</a>
        </div>

        <footer class="text-center text-muted mt-5 py-4">
          <small>Univ_Pass &middot; 본 분석 결과는 참고용이며, 실제 입시 결과와 다를 수 있습니다.</small>
        </footer>
      </div>
    </div>
  </div>

  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
  <script>
    const SAVE_DATA = {
      student: <%- JSON.stringify(student) %>,
      results: <%- JSON.stringify(results) %>,
      highProb: <%- JSON.stringify(highProb) %>,
      midProb: <%- JSON.stringify(midProb) %>,
      lowProb: <%- JSON.stringify(lowProb) %>,
      totalUnivs: <%- totalUnivs %>,
      deptQuery: <%- JSON.stringify(deptQuery || '') %>,
      admissionType: '<%= admissionType %>'
    }

    async function saveResult() {
      const btn = document.getElementById('saveBtn')
      btn.disabled = true
      btn.textContent = '저장 중...'
      try {
        const res = await fetch('/api/save-result', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify(SAVE_DATA)
        })
        const data = await res.json()
        if (data.success) {
          const ind = document.getElementById('saveIndicator')
          ind.innerHTML = '✅ 저장됨 <a href="/saved/' + data.id + '" class="text-decoration-none">#</a>'
          ind.style.display = ''
          btn.textContent = '💾 저장 완료'
        } else {
          btn.textContent = '저장 실패'
          btn.disabled = false
        }
      } catch (e) {
        btn.textContent = '오류'
        btn.disabled = false
      }
    }
  </script>
</body>
</html>
