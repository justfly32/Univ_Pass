<!DOCTYPE html>
<html lang="ko">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Univ_Pass - 대학 기준 관리</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
  <link rel="stylesheet" href="/style.css">
</head>
<body>
  <div class="container py-5">
    <div class="d-flex justify-content-between align-items-center mb-4">
      <div>
        <h1 class="fw-bold" style="font-size:1.8rem; color:var(--primary);">대학 기준 관리</h1>
        <p class="text-muted mb-0">각 대학의 수시 기준을 확인하고 수정하세요</p>
      </div>
      <a href="/" class="btn btn-outline-primary">분석 화면</a>
    </div>

    <div class="row g-3">
      <% 
        var metro = { label: '수도권', univs: [] }
        var nonMetro = { label: '비수도권', univs: [] }
        var metroRegions = ['서울', '경기', '인천', '수원']
        universities.forEach(function(u) {
          if (metroRegions.includes(u.region)) {
            metro.univs.push(u)
          } else {
            nonMetro.univs.push(u)
          }
        })
        var groups = [metro, nonMetro]
      %>
      <% groups.forEach(function(group) { %>
        <div class="col-12">
          <h5 class="fw-bold mt-3 mb-2 pb-1" style="color:var(--gray-500); border-bottom:2px solid var(--gray-200);"><%= group.label %> (<%= group.univs.length %>)</h5>
        </div>
        <% group.univs.forEach(function(u) { %>
          <div class="col-md-4 col-lg-3">
            <div class="card univ-card h-100">
              <div class="card-body d-flex flex-column">
                <div class="d-flex justify-content-between align-items-start mb-2">
                  <h6 class="fw-bold mb-0" style="color:var(--gray-800);"><%= u.name %></h6>
                  <span class="badge bg-secondary" style="font-size:0.7rem;"><%= u.type %></span>
                </div>
                <div class="small text-muted mb-2"><%= u.departmentCount %>개 학과</div>
                <div class="mt-auto d-flex gap-2 flex-wrap">
                  <% if (u.admission_url) { %>
                    <a href="<%= u.admission_url %>" target="_blank" class="btn btn-sm btn-outline-info">입학처</a>
                  <% } %>

                  <% if (u.cutoff_url) { %>
                    <a href="<%= u.cutoff_url %>" target="_blank" class="btn btn-sm btn-outline-warning">입결내역</a>
                  <% } %>
                  <a href="/admin/<%= u.id %>" class="btn btn-sm btn-primary">편집</a>
                </div>
              </div>
            </div>
          </div>
        <% }) %>
      <% }) %>
    </div>

    <div class="text-center mt-4">
      <a href="/" class="btn btn-outline-primary">분석 화면으로 돌아가기</a>
    </div>
  </div>
</body>
</html>
